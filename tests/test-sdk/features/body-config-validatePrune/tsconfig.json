{
  "extends": "../../../config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@api": [
        "./src/api"
      ],
      "@api/lib/*": [
        "./src/api/*"
      ]
    },
    "plugins": [
      {
        "transform": "@nestia/core/lib/transform",
        "validate": "validatePrune"
      }
    ]
  },
  "include": [
    "src"
  ]
}
