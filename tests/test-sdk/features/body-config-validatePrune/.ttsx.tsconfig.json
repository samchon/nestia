{
  "extends": "./tsconfig.json",
  "exclude": [],
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": ".",
    "plugins": [
      {
        "transform": "typia/lib/transform",
        "enabled": false
      },
      {
        "transform": "@nestia/sdk/lib/transform"
      },
      {
        "transform": "@nestia/core/native/transform.cjs",
        "validate": "validatePrune"
      }
    ],
    "rootDir": "."
  }
}