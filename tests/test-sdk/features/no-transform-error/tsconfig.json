{
  "extends": "../../config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@api": ["./src/api"],
      "@api/lib/*": ["./src/api/*"],
    },
    "plugins": [
      { "transform": "@nestia/core/lib/transform", "enabled": false },
      { "transform": "@nestia/sdk/lib/transform", "enabled": false },
    ],
  },
  "include": ["src"],
}
