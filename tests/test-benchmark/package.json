{
  "private": true,
  "name": "@nestia/test-benchmark",
  "version": "12.0.0-rc.2",
  "scripts": {
    "dev": "ttsc --watch",
    "start": "cross-env TTSC_GO_BINARY=go TTSC_CACHE_DIR=../../node_modules/.cache/ttsc NODE_OPTIONS=\"--no-experimental-strip-types --no-experimental-detect-module\" ttsx -r @nestjs/platform-express src/index.ts"
  },
  "dependencies": {
    "@nestia/benchmark": "workspace:^",
    "@nestia/core": "workspace:^",
    "@nestia/e2e": "workspace:^",
    "@nestia/fetcher": "workspace:^",
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@nestjs/platform-express": "catalog:nestjs",
    "typia": "catalog:samchon",
    "uuid": "catalog:utils"
  },
  "devDependencies": {
    "@nestia/sdk": "workspace:^",
    "@types/node": "catalog:utils",
    "@types/uuid": "catalog:utils",
    "cross-env": "catalog:utils",
    "nestia": "workspace:^",
    "ttsc": "catalog:typescript"
  },
  "packageManager": "pnpm@10.6.4"
}
