{
  "name": "@nestia/sdk",
  "version": "12.0.0-dev.20260521.2",
  "description": "Nestia SDK and Swagger generator",
  "types": "lib/index.d.ts",
  "main": "lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json",
    "./lib/executable/sdk": {
      "types": "./lib/executable/sdk.d.ts",
      "default": "./lib/executable/sdk.js"
    },
    "./lib/transform": {
      "types": "./src/transform.ts",
      "default": "./lib/transform.js"
    },
    "./src/transform.ts": "./src/transform.ts"
  },
  "tsp": {
    "tscOptions": {
      "parseAllJsDoc": true
    }
  },
  "bin": {
    "@nestia/sdk": "lib/executable/sdk.js"
  },
  "scripts": {
    "build": "rimraf lib && ttsc",
    "dev": "ttsc --watch",
    "prepack": "pnpm run build",
    "test:go": "cd test && go test ./..."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestia",
    "sdk",
    "swagger",
    "generator",
    "nestjs",
    "typia"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "dependencies": {
    "@nestia/core": "workspace:^",
    "@nestia/factory": "workspace:^",
    "@nestia/fetcher": "workspace:^",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "get-function-location": "^2.0.0",
    "glob": "^11.0.3",
    "path-to-regexp": "^6.2.1",
    "prettier": "catalog:typescript",
    "ttsc": "catalog:typescript",
    "tstl": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "peerDependencies": {
    "@nestia/core": "workspace:^"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@typescript/native-preview": "catalog:typescript",
    "@types/express": "^4.17.15",
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils"
  },
  "files": [
    "assets",
    "lib",
    "native/go.mod",
    "native/go.sum",
    "native/sdk",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./lib/executable/sdk": {
        "types": "./lib/executable/sdk.d.ts",
        "default": "./lib/executable/sdk.js"
      },
      "./lib/transform": {
        "types": "./lib/transform.d.ts",
        "default": "./lib/transform.js"
      },
      "./package.json": "./package.json"
    },
    "bin": {
      "@nestia/sdk": "./lib/executable/sdk.js"
    }
  }
}
