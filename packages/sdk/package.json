{
  "name": "@nestia/sdk",
  "version": "9.0.0-dev.20251107-3",
  "description": "Nestia SDK and Swagger generator",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./lib/executable/sdk": "./src/executable/sdk.ts"
  },
  "bin": {
    "@nestia/sdk": "src/executable/sdk.ts"
  },
  "scripts": {
    "build": "rimraf lib && tsc",
    "dev": "rimraf lib && tsc --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestia",
    "sdk",
    "swagger",
    "generator",
    "nestjs",
    "typia"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "dependencies": {
    "@nestia/core": "workspace:^",
    "@nestia/fetcher": "workspace:^",
    "@typia/core": "catalog:samchon",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "cli": "^1.0.1",
    "get-function-location": "^2.0.0",
    "glob": "^11.0.3",
    "path-to-regexp": "^6.2.1",
    "prettier": "catalog:typescript",
    "ts-node": ">=10.6.0",
    "tsconfck": "^2.1.2",
    "tsconfig-paths": "^4.1.1",
    "tstl": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "peerDependencies": {
    "@nestia/core": "workspace:^"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@types/cli": "^0.11.21",
    "@types/express": "^4.17.15",
    "@types/node": "catalog:utils",
    "@types/ts-expose-internals": "npm:ts-expose-internals@5.4.5",
    "rimraf": "catalog:utils",
    "typescript": "catalog:typescript"
  },
  "files": [
    "assets",
    "lib",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./cli": {
        "types": "./lib/executable/sdk.d.ts",
        "default": "./lib/executable/sdk.js"
      },
      "./package.json": "./package.json"
    },
    "bin": {
      "@nestia/sdk": "./lib/executable/sdk.js"
    }
  }
}