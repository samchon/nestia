{
  "name": "@nestia/core",
  "version": "11.0.0-dev.20260313-3",
  "description": "Super-fast validation decorators of NestJS",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./lib/transform": "./src/transform.ts",
    "./src/transform.ts": "./src/transform.ts"
  },
  "tsp": {
    "tscOptions": {
      "parseAllJsDoc": true
    }
  },
  "scripts": {
    "build": "rimraf lib && tsc",
    "dev": "rimraf lib && tsc --watch",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestjs",
    "nestia",
    "typia",
    "validator",
    "decorator",
    "class-validator",
    "class-transformer"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "dependencies": {
    "@nestia/fetcher": "workspace:^",
    "@typia/core": "catalog:samchon",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "detect-ts-node": "^1.0.5",
    "get-function-location": "^2.0.0",
    "glob": "^11.0.3",
    "path-parser": "^6.1.0",
    "raw-body": "^2.0.0",
    "reflect-metadata": ">=0.1.12",
    "rxjs": ">=6.0.3",
    "tgrid": "^1.1.0",
    "typia": "catalog:samchon",
    "ws": "^7.5.3"
  },
  "peerDependencies": {
    "@nestia/fetcher": "workspace:^",
    "@nestjs/common": ">=7.0.1",
    "@nestjs/core": ">=7.0.1",
    "reflect-metadata": ">=0.1.12",
    "rxjs": ">=6.0.3",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@nestjs/platform-express": "catalog:nestjs",
    "@types/express": "^4.17.15",
    "@types/inquirer": "^9.0.3",
    "@types/multer": "^1.4.12",
    "@types/ws": "^8.5.10",
    "commander": "^10.0.0",
    "comment-json": "^4.2.3",
    "eslint-plugin-deprecation": "^1.4.1",
    "fastify": "^4.28.1",
    "git-last-commit": "^1.0.1",
    "inquirer": "^8.2.5",
    "rimraf": "catalog:utils",
    "ts-node": "catalog:typescript",
    "tstl": "catalog:samchon",
    "typescript": "catalog:typescript"
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "lib",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./lib/transform": {
        "types": "./lib/transform.d.ts",
        "default": "./lib/transform.js"
      },
      "./package.json": "./package.json"
    }
  }
}