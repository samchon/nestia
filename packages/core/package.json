{
  "name": "@nestia/core",
  "version": "12.0.0-dev.20260601.1",
  "description": "Super-fast validation decorators of NestJS",
  "types": "lib/index.d.ts",
  "main": "lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json",
    "./lib/transform": {
      "types": "./src/transform.ts",
      "default": "./lib/transform.js"
    },
    "./native/transform.cjs": "./native/transform.cjs",
    "./src/transform.ts": "./src/transform.ts"
  },
  "tsp": {
    "tscOptions": {
      "parseAllJsDoc": true
    }
  },
  "scripts": {
    "build": "rimraf lib && ttsc",
    "dev": "ttsc --watch",
    "prepack": "pnpm run build",
    "test:go": "cd test && go test ./..."
  },
  "ttsc": {
    "plugin": {
      "transform": "@nestia/core/native/transform.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestjs",
    "nestia",
    "typia",
    "validator",
    "decorator",
    "class-validator",
    "class-transformer"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "dependencies": {
    "@nestia/fetcher": "workspace:^",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "get-function-location": "^2.0.0",
    "glob": "^11.0.3",
    "path-parser": "^6.1.0",
    "raw-body": "^2.0.0",
    "reflect-metadata": ">=0.1.12",
    "rxjs": ">=6.0.3",
    "tgrid": "^1.1.0",
    "typia": "catalog:samchon",
    "ws": "^7.5.3"
  },
  "peerDependencies": {
    "@nestia/fetcher": "workspace:^",
    "@nestjs/common": ">=7.0.1",
    "@nestjs/core": ">=7.0.1",
    "reflect-metadata": ">=0.1.12",
    "rxjs": ">=6.0.3",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@nestjs/platform-express": "catalog:nestjs",
    "@typescript/native-preview": "catalog:typescript",
    "@types/express": "^4.17.15",
    "@types/multer": "^1.4.12",
    "@types/ws": "^8.5.10",
    "fastify": "^4.28.1",
    "rimraf": "catalog:utils",
    "ttsc": "catalog:typescript",
    "tstl": "catalog:samchon"
  },
  "files": [
    "README.md",
    "MIGRATION.md",
    "LICENSE",
    "package.json",
    "lib",
    "native/cmd",
    "native/go.mod",
    "native/go.sum",
    "native/plugin",
    "native/transform",
    "native/transform.cjs",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./lib/transform": {
        "types": "./lib/transform.d.ts",
        "default": "./lib/transform.js"
      },
      "./native/transform.cjs": "./native/transform.cjs",
      "./package.json": "./package.json"
    }
  }
}
