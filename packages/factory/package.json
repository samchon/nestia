{
  "name": "@nestia/factory",
  "version": "11.2.0",
  "description": "Printer-compatible TypeScript AST node factory for Nestia generators",
  "types": "lib/index.d.ts",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && tsc && rollup -c",
    "dev": "rimraf lib && tsc --watch",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestia",
    "factory"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "devDependencies": {
    "@rollup/plugin-typescript": "catalog:rollup",
    "rimraf": "catalog:utils",
    "rollup": "catalog:rollup",
    "typescript": "catalog:typescript"
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "lib",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "module": "lib/index.mjs",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "import": "./lib/index.mjs",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  }
}
