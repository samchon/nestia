{
  "name": "nestia",
  "version": "12.0.0-dev.20260601.1",
  "description": "Nestia CLI tool",
  "main": "bin/index.js",
  "bin": {
    "nestia": "bin/index.js"
  },
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "default": "./bin/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf bin && ttsc",
    "dev": "rimraf bin && ttsc --watch",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestia",
    "cli",
    "sdk",
    "swagger",
    "generator",
    "nestjs",
    "typia"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "devDependencies": {
    "@nestia/core": "workspace:^",
    "@nestia/sdk": "workspace:^",
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "types": "bin/index.d.ts",
    "main": "bin/index.js",
    "exports": {
      ".": {
        "types": "./bin/index.d.ts",
        "default": "./bin/index.js"
      },
      "./package.json": "./package.json"
    },
    "bin": {
      "nestia": "./bin/index.js"
    }
  }
}
