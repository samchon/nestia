{
  "name": "nestia",
  "version": "9.0.0-dev.20251107-3",
  "description": "Nestia CLI tool",
  "main": "src/index.ts",
  "bin": {
    "nestia": "src/boot.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf bin && tsc",
    "dev": "rimraf bin && tsc --watch",
    "package:latest": "npm run build && npm publish --access public --tag latest",
    "package:next": "npm run build && npm publish --access public --tag next"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestia",
    "cli",
    "sdk",
    "swagger",
    "generator",
    "nestjs",
    "typia"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "dependencies": {
    "commander": "^10.0.0",
    "comment-json": "^4.2.3",
    "inquirer": "^8.2.5",
    "package-manager-detector": "^0.2.0"
  },
  "devDependencies": {
    "@nestia/core": "workspace:^",
    "@nestia/sdk": "workspace:^",
    "@types/inquirer": "^9.0.3",
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "ts-node": "catalog:typescript",
    "typescript": "catalog:typescript"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "types": "bin/index.d.ts",
    "main": "bin/index.js",
    "exports": {
      ".": {
        "types": "./bin/index.d.ts",
        "default": "./bin/index.js"
      },
      "./package.json": "./package.json"
    },
    "bin": {
      "nestia": "./bin/index.js"
    }
  }
}