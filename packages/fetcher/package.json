{
  "name": "@nestia/fetcher",
  "version": "12.0.0-rc.4",
  "description": "Fetcher library of Nestia SDK",
  "types": "lib/index.d.ts",
  "main": "lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "default": "./lib/index.js"
    },
    "./lib/AesPkcs5": {
      "types": "./lib/AesPkcs5.d.ts",
      "import": "./lib/AesPkcs5.mjs",
      "default": "./lib/AesPkcs5.js"
    },
    "./lib/EncryptedFetcher": {
      "types": "./lib/EncryptedFetcher.d.ts",
      "import": "./lib/EncryptedFetcher.mjs",
      "default": "./lib/EncryptedFetcher.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && ttsc && rolldown -c && node ../../deploy/verify-package-exports.cjs --require-main --esm",
    "dev": "rimraf lib && ttsc --watch",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "nestia",
    "fetcher",
    "sdk"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "dependencies": {
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon"
  },
  "devDependencies": {
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "rolldown": "catalog:rolldown"
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "lib",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "import": "./lib/index.mjs",
        "default": "./lib/index.js"
      },
      "./lib/AesPkcs5": {
        "types": "./lib/AesPkcs5.d.ts",
        "import": "./lib/AesPkcs5.mjs",
        "default": "./lib/AesPkcs5.js"
      },
      "./lib/EncryptedFetcher": {
        "types": "./lib/EncryptedFetcher.d.ts",
        "import": "./lib/EncryptedFetcher.mjs",
        "default": "./lib/EncryptedFetcher.js"
      },
      "./package.json": "./package.json"
    }
  }
}
