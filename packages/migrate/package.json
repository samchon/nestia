{
  "name": "@nestia/migrate",
  "version": "8.0.5-dev.20250904-2",
  "description": "Migration program from swagger to NestJS",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "bin": {
    "@nestia/migrate": "src/executable/migrate.ts"
  },
  "scripts": {
    "build": "rimraf lib && tsc && rollup -c",
    "bundle": "node src/executable/bundle.js",
    "dev": "rimraf lib && tsc --watch",
    "package:next": "npm publish --access public --tag next",
    "prepare": "npm run bundle",
    "test": "node lib/test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "migration",
    "swagger",
    "openapi generator",
    "NestJS",
    "nestia",
    "SDK",
    "RPC",
    "Mockup Simulator"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/inquirer": "^9.0.7",
    "@types/node": "catalog:utils",
    "rimraf": "^6.0.1",
    "rollup": "^4.24.3"
  },
  "dependencies": {
    "@samchon/openapi": "catalog:samchon",
    "commander": "10.0.0",
    "inquirer": "8.2.5",
    "prettier": "^3.3.3",
    "prettier-plugin-jsdoc": "^1.3.2",
    "tstl": "catalog:samchon",
    "typescript": "catalog:typescript",
    "typia": "catalog:samchon"
  },
  "files": [
    "lib",
    "src",
    "!lib/test",
    "!src/test",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "module": "lib/index.mjs",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "import": "./lib/index.mjs",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  }
}