{
  "name": "@nestia/migrate",
  "version": "12.0.0-rc.3",
  "description": "Migration program from swagger to NestJS",
  "main": "lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "@nestia/migrate": "lib/executable/migrate.js"
  },
  "scripts": {
    "build": "rimraf lib && ttsc && tsc --emitDeclarationOnly && rolldown -c && node ../../deploy/verify-package-exports.cjs --esm",
    "bundle": "node src/executable/bundle.js",
    "dev": "rimraf lib && ttsc --watch",
    "prepack": "pnpm run build",
    "prepare": "npm run bundle",
    "test": "node lib/test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "keywords": [
    "migration",
    "swagger",
    "openapi generator",
    "NestJS",
    "nestia",
    "SDK",
    "RPC",
    "Mockup Simulator"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "catalog:utils",
    "js-yaml": "^4.1.0",
    "rimraf": "catalog:utils",
    "rolldown": "catalog:rolldown",
    "typescript": "catalog:typescript"
  },
  "dependencies": {
    "@trivago/prettier-plugin-sort-imports": "catalog:typescript",
    "@ttsc/factory": "catalog:typescript",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "commander": "10.0.0",
    "inquirer": "8.2.5",
    "prettier": "catalog:typescript",
    "prettier-plugin-jsdoc": "catalog:typescript",
    "tstl": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "files": [
    "lib",
    "src",
    "!lib/test",
    "!src/test",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "types": "lib/index.d.ts",
    "main": "lib/index.js",
    "bin": {
      "@nestia/migrate": "./lib/executable/migrate.js"
    },
    "module": "lib/index.mjs",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "import": "./lib/index.mjs",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  }
}
