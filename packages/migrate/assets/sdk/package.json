{
  "name": "@ORGANIZATION/PROJECT-api",
  "version": "0.1.0",
  "description": "SDK library generated by Nestia",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "rimraf lib && tsc && rollup -c",
    "build:test": "rimraf bin && tsc --project test/tsconfig.json",
    "deploy": "npm run build && npm publish",
    "dev": "npm run build:test -- --watch",
    "hello": "node hello",
    "prepare": "ts-patch install && typia patch",
    "start": "ts-node test/start.ts",
    "swagger": "ts-node test/swagger.ts",
    "test": "ts-node test/index.ts",
    "test:simulate": "ts-node test/index.ts --simulate true",
    "test:manual": "ts-node test/manual.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "files": [
    "lib",
    "swagger.json",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@nestia/fetcher": "^10.0.2",
    "tgrid": "^1.2.1",
    "typia": "^11.0.3"
  },
  "devDependencies": {
    "@nestia/e2e": "^10.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/inquirer": "8.2.5",
    "@types/swagger-ui-express": "^4.1.6",
    "chalk": "4.1.2",
    "commander": "^10.0.0",
    "express": "^4.19.2",
    "inquirer": "8.2.5",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "rollup": "^4.13.2",
    "swagger-ui-express": "^5.0.0",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "typescript": "~5.9.3",
    "typescript-transform-paths": "^3.5.6"
  }
}
