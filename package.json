{
  "private": true,
  "name": "@nestia/station",
  "version": "10.0.2",
  "description": "Nestia station",
  "scripts": {
    "build": "pnpm --filter=./packages/* -r build",
    "format": "prettier --write packages/**/*.ts && prettier --write internals/**/*.ts && prettier --write tests/**/*.ts",
    "test": "pnpm --filter=./tests/test-* -r start",
    "package:latest": "node deploy publish --tag latest",
    "package:next": "node deploy publish --tag next --migrate",
    "prepare": "ts-patch install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "prettier": "^3.2.4",
    "prettier-plugin-jsdoc": "^1.3.2",
    "rimraf": "^6.0.1",
    "sloc": "^0.3.0",
    "ts-patch": "catalog:typescript",
    "typescript": "catalog:typescript"
  },
  "packageManager": "pnpm@10.6.4"
}
