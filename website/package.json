{
  "type": "module",
  "name": "nestia.io",
  "version": "3.1.1",
  "description": "Nestia Guide Documents",
  "private": true,
  "scripts": {
    "build": "npm run prebuild && next build && npm run postbuild",
    "prebuild": "rimraf .next && rimraf out && npm run build:editor && npm run build:typedoc && npm run build:blog:rss",
    "postbuild": "npm run build:pagefind && npm run build:sitemap",
    "build:blog:rss": "node build/blog",
    "build:editor": "node build/editor",
    "build:pagefind": "pagefind --site .next/server/app --output-path out/_pagefind",
    "build:sitemap": "node build/sitemap",
    "build:typedoc": "node build/typedoc",
    "deploy": "node build/deploy",
    "dev": "npm run build:editor && next dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "dependencies": {
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@mui/system": "^6.4.0",
    "@nestia/editor": "../deploy/tarballs/editor.tgz",
    "@nestia/migrate": "../deploy/tarballs/migrate.tgz",
    "next": "^15.3.4",
    "nextra": "^4.6.0",
    "nextra-theme-blog": "^4.6.1",
    "nextra-theme-docs": "^4.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "18.11.10",
    "@types/react": "18.0.35",
    "gh-pages": "^5.0.0",
    "jszip": "^3.10.1",
    "next-sitemap": "^4.2.3",
    "pagefind": "^1.3.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.14",
    "typescript": "~5.9.3"
  }
}
